<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="28dp"
    android:background="@drawable/dialog_rounded_bg"
    android:gravity="center_horizontal">

    <!-- Premium top handle indicator for Bottom Sheet -->
    <View
        android:layout_width="48dp"
        android:layout_height="4dp"
        android:layout_marginBottom="20dp"
        android:background="#CBD5E1"
        android:backgroundTint="?attr/colorOutline" />

    <FrameLayout
        android:id="@+id/micContainer"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp">

        <!-- Outer glowing pulsing rings -->
        <View
            android:id="@+id/micPulse"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="@drawable/circle_pulse" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/voiceMicButton"
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:layout_gravity="center"
            android:contentDescription="Mic"
            android:src="@android:drawable/ic_btn_speak_now"
            app:backgroundTint="?attr/colorPrimary"
            app:tint="?attr/colorOnPrimary"
            app:fabCustomSize="84dp"
            app:maxImageSize="42dp"
            app:elevation="8dp" />

    </FrameLayout>

    <TextView
        android:id="@+id/voiceStatusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/voice_listening_hint"
        android:textSize="16sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textStyle="bold"
        android:letterSpacing="0.02"
        android:gravity="center" />

    <TextView
        android:id="@+id/recognizedSpeech"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="8dp"
        android:textSize="19sp"
        android:textColor="?attr/colorOnSurface"
        android:textStyle="italic"
        android:gravity="center"
        android:visibility="gone"
        android:lineSpacingMultiplier="1.2"
        android:minLines="2" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/confirmationCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:visibility="gone"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:strokeWidth="1.5dp"
        app:strokeColor="?attr/colorPrimaryContainer"
        app:contentPadding="20dp"
        app:cardBackgroundColor="?attr/colorSurfaceVariant">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/confirmationTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:letterSpacing="0.01" />

            <TextView
                android:id="@+id/confirmationDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textSize="15sp"
                android:lineSpacingMultiplier="1.1"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="14dp"
                android:background="?attr/colorOutlineVariant" />

            <TextView
                android:id="@+id/confirmationBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="?attr/colorPrimary" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/confirmButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        android:visibility="gone"
        android:weightSum="2">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmYes"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="हाँ (Sahi Hai)"
            android:textSize="15sp"
            android:textStyle="bold"
            app:cornerRadius="16dp"
            app:icon="@android:drawable/ic_menu_send"
            app:iconTint="?attr/colorOnPrimary"
            style="@style/Widget.Material3.Button" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmNo"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="नहीं (Badlo)"
            android:textSize="15sp"
            android:textColor="?attr/colorError"
            app:cornerRadius="16dp"
            app:icon="@android:drawable/ic_menu_close_clear_cancel"
            app:iconTint="?attr/colorError"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:strokeColor="?attr/colorError" />

    </LinearLayout>

    <TextView
        android:id="@+id/holdHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/voice_mic_hold_hint"
        android:textSize="13sp"
        android:textColor="?attr/colorOutline"
        android:visibility="gone" />

    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/voiceProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        app:indicatorSize="28dp"
        app:trackThickness="3dp"
        app:indicatorColor="?attr/colorPrimary" />

</LinearLayout>
