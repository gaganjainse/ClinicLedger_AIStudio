<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ========================================== -->
    <!-- Material 3 Typography Scale (Font Sizes)  -->
    <!-- ========================================== -->

    <!-- Display Sizes -->
    <dimen name="text_size_display_large">57sp</dimen>
    <dimen name="text_size_display_medium">45sp</dimen>
    <dimen name="text_size_display_small">36sp</dimen>

    <!-- Headline Sizes -->
    <dimen name="text_size_headline_large">32sp</dimen>   <!-- e.g. Balance amount -->
    <dimen name="text_size_headline_medium">28sp</dimen>
    <dimen name="text_size_headline_small">24sp</dimen>
    <dimen name="text_size_headline_alt">26sp</dimen>     <!-- e.g. Patient name -->

    <!-- Title Sizes -->
    <dimen name="text_size_title_large">22sp</dimen>      <!-- e.g. Analytics card headers, Dialog titles -->
    <dimen name="text_size_title_medium">18sp</dimen>     <!-- e.g. Card headers -->
    <dimen name="text_size_title_small">14sp</dimen>      <!-- e.g. Section titles / labels -->
    <dimen name="text_size_title_alt_large">20sp</dimen>  <!-- e.g. Secondary dialog titles -->
    <dimen name="text_size_title_alt_medium">19sp</dimen> <!-- e.g. Dynamic speech state info -->

    <!-- Body Sizes -->
    <dimen name="text_size_body_large">16sp</dimen>       <!-- e.g. Primary list content, input fields -->
    <dimen name="text_size_body_medium">14sp</dimen>      <!-- e.g. Secondary info, text prompts -->
    <dimen name="text_size_body_small">12sp</dimen>       <!-- e.g. Tiny list info, badges, labels -->
    <dimen name="text_size_body_dense">13sp</dimen>       <!-- e.g. Condensed details, buttons -->
    <dimen name="text_size_body_sparse">15sp</dimen>      <!-- e.g. Speech prompt text, large actions -->

    <!-- Label Sizes -->
    <dimen name="text_size_label_large">14sp</dimen>
    <dimen name="text_size_label_medium">12sp</dimen>
    <dimen name="text_size_label_small">11sp</dimen>      <!-- e.g. Small tags, hint texts -->
    <dimen name="text_size_label_micro">10sp</dimen>      <!-- e.g. Very tiny nodes, helper text -->

    <!-- ========================================== -->
    <!-- Layout Dimensions (Spacing & Corners)      -->
    <!-- ========================================== -->
    <dimen name="voice_bar_height">68dp</dimen>
    <dimen name="voice_bar_margin">16dp</dimen>
    <dimen name="voice_bar_bottom_padding">84dp</dimen>

    <dimen name="card_corner_small">8dp</dimen>
    <dimen name="card_corner_medium">16dp</dimen>
    <dimen name="card_corner_large">20dp</dimen>
    <dimen name="card_corner_xlarge">24dp</dimen>
    <dimen name="card_corner_xxlarge">28dp</dimen>

    <dimen name="screen_padding">16dp</dimen>
    <dimen name="card_padding">20dp</dimen>
</resources>
